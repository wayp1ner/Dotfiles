# ----------
# - Output -
# ----------
# You can get the names of your outputs by running: swaymsg -t get_outputs

# output <name> <options...>
# enable|disable
# mode <WxH>@<Hz>      # resolution + refresh rate (add 'custom' to force resolution/refresh rate)
# position <x> <y>     # layout: (eg: 0 0 = mirror, 1920 0 = right, 0 1080 = below)
# scale <float>        # hidpi scaling
# transform <angle>    # rotate (0/90/180/270)
# adaptive_sync on|off # freesync/vrr
# max_render_time <ms> # frame render limit

# Screen config
output eDP-1 {

}

output HDMI-A-1 {

}

# Reduce latency
output * {
    allow_tearing yes
    max_render_time off
}

